---
import Predictor from "../components/Predictor";
import HowItWorksBehind from "../components/HowItWorksBehind";
import HowItWorks from "../components/HowItWorks";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="/logo.png" />
        <title>SmartPrice - Predictor Inteligente de Precios</title>
        <!-- Google Fonts: Outfit & Inter -->
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="bg-[#030712] text-slate-200 antialiased selection:bg-cyan-500 selection:text-white relative min-h-screen overflow-x-hidden"
    >
        <!-- Background Grid Pattern -->
        <div
            class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none z-0 opacity-40"
        >
        </div>

        <div class="relative w-full overflow-hidden glow-bg">
            <!-- Floating Aurora Background Blobs -->
            <div class="aurora-blob aurora-1"></div>
            <div class="aurora-blob aurora-2"></div>

            <!-- Navbar Simple -->
            <nav
                class="container mx-auto px-6 py-6 flex justify-between items-center relative z-10"
            >
                <a
                    href="#"
                    class="flex items-center gap-3.5 group relative z-10 select-none"
                >
                    <div
                        class="h-16 w-auto overflow-hidden bg-transparent transition-all duration-300 group-hover:scale-[1.03] group-hover:drop-shadow-[0_0_12px_rgba(6,182,212,0.4)]"
                    >
                        <img
                            src="/logo.png"
                            alt="SmartPrice Logo"
                            class="h-full w-auto object-contain"
                        />
                    </div>
                    <div
                        class="text-2xl font-black text-white tracking-tight font-display"
                        id="logo"
                    >
                        Smart<span class="text-cyan-400">Price</span>
                    </div>
                </a>
                <div class="flex gap-6 items-center">
                    <a
                        href="#agente"
                        class="text-sm font-semibold text-slate-300 hover:text-white transition-colors font-display"
                    >
                        Predecir
                    </a>
                    <a
                        href="#como-funciona-detras"
                        class="text-sm font-semibold text-slate-300 hover:text-white transition-colors font-display"
                    >
                        Cómo Funciona
                    </a>
                </div>
            </nav>

            <!-- HERO SECTION -->
            <section
                class="container mx-auto px-6 pt-24 pb-28 flex flex-col items-center text-center relative z-10 min-h-[70vh] justify-center"
            >
                <div
                    class="inline-flex items-center gap-2.5 px-4 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-xs font-semibold mb-8 opacity-0 tracking-wide uppercase shadow-[0_0_15px_rgba(6,182,212,0.1)]"
                    id="hero-badge"
                >
                    <span class="relative flex h-2.5 w-2.5">
                        <span
                            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"
                        ></span>
                        <span
                            class="relative inline-flex rounded-full h-2.5 w-2.5 bg-cyan-500"
                        ></span>
                    </span>
                    Modelo Predictivo Entrenado
                </div>

                <h1
                    class="text-5xl md:text-8xl font-black text-white mb-8 max-w-5xl tracking-tight leading-none opacity-0 font-display"
                    id="hero-title"
                >
                    SmartPrice: El Agente<br /><span
                        class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 via-sky-400 to-indigo-400"
                        >que predice el futuro.</span
                    >
                </h1>

                <p
                    class="text-lg md:text-xl text-slate-400 max-w-3xl mb-12 leading-relaxed opacity-0 font-medium"
                    id="hero-desc"
                >
                    Ingresa las especificaciones del vehículo. Nuestro modelo de
                    Machine Learning analizará miles de registros históricos
                    para predecir el precio de mercado exacto.
                </p>

                <a
                    href="#agente"
                    class="group relative px-8 py-4.5 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-bold rounded-xl hover:from-cyan-400 hover:to-blue-500 transition-all duration-300 shadow-[0_0_30px_rgba(6,182,212,0.2)] hover:shadow-[0_0_40px_rgba(6,182,212,0.45)] hover:scale-[1.03] flex items-center gap-2.5 opacity-0 font-display text-sm uppercase tracking-wider"
                    id="hero-btn"
                >
                    Iniciar Predicción
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-4.5 w-4.5 group-hover:translate-x-1 transition-transform"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                            clip-rule="evenodd"></path>
                    </svg>
                </a>
            </section>

            <!-- Metrics / Features section -->
            <div
                class="container mx-auto px-6 pb-24 relative z-10"
                id="metrics"
            >
                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto"
                >
                    <div
                        class="glass-card p-6.5 rounded-3xl border border-slate-800/80 bg-slate-950/40 backdrop-blur-md hover:border-cyan-500/40 hover:bg-slate-900/40 hover:shadow-[0_0_30px_rgba(6,182,212,0.05)] transition-all duration-500 group opacity-0 metric-card"
                    >
                        <div
                            class="w-11 h-11 rounded-2xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 mb-5 group-hover:scale-110 group-hover:bg-cyan-500/20 transition-all duration-300"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M21.21 15.89A10 10 0 1 1 8 2.83"
                                ></path><path d="M22 12A10 10 0 0 0 12 2v10z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="text-lg font-bold text-white mb-2 font-display"
                        >
                            Dataset Histórico
                        </h3>
                        <p class="text-sm text-slate-400 leading-relaxed">
                            Más de 16,000 registros depurados y mapeados para un
                            análisis estadístico robusto.
                        </p>
                    </div>
                    <div
                        class="glass-card p-6.5 rounded-3xl border border-slate-800/80 bg-slate-950/40 backdrop-blur-md hover:border-indigo-500/40 hover:bg-slate-900/40 hover:shadow-[0_0_30px_rgba(99,102,241,0.05)] transition-all duration-500 group opacity-0 metric-card"
                    >
                        <div
                            class="w-11 h-11 rounded-2xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 mb-5 group-hover:scale-110 group-hover:bg-indigo-500/20 transition-all duration-300"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                ></path></svg
                            >
                        </div>
                        <h3
                            class="text-lg font-bold text-white mb-2 font-display"
                        >
                            Precisión Probada
                        </h3>
                        <p class="text-sm text-slate-400 leading-relaxed">
                            R² Score superior al 77.9% gracias al ajuste de
                            hiperparámetros en el ensamble Random Forest.
                        </p>
                    </div>
                    <div
                        class="glass-card p-6.5 rounded-3xl border border-slate-800/80 bg-slate-950/40 backdrop-blur-md hover:border-purple-500/40 hover:bg-slate-900/40 hover:shadow-[0_0_30px_rgba(168,85,247,0.05)] transition-all duration-500 group opacity-0 metric-card"
                    >
                        <div
                            class="w-11 h-11 rounded-2xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400 mb-5 group-hover:scale-110 group-hover:bg-purple-500/20 transition-all duration-300"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect
                                    x="3"
                                    y="3"
                                    width="18"
                                    height="18"
                                    rx="2"
                                    ry="2"></rect><line
                                    x1="9"
                                    y1="3"
                                    x2="9"
                                    y2="21"></line><line
                                    x1="15"
                                    y1="3"
                                    x2="15"
                                    y2="21"></line><line
                                    x1="3"
                                    y1="9"
                                    x2="21"
                                    y2="9"></line><line
                                    x1="3"
                                    y1="15"
                                    x2="21"
                                    y2="15"></line></svg
                            >
                        </div>
                        <h3
                            class="text-lg font-bold text-white mb-2 font-display"
                        >
                            Target Encoding
                        </h3>
                        <p class="text-sm text-slate-400 leading-relaxed">
                            Codificación inteligente para marcas y modelos que
                            captura la variación real de la devaluación.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- PREDICCIÓN / FORMULARIO SECTION -->
        <section id="agente" class="container mx-auto px-6 py-24">
            <Predictor client:load />
        </section>

        <!-- CÓMO FUNCIONA DETRÁS DE ESCENA -->
        <section
            id="como-funciona-detras"
            class="container mx-auto px-6 py-24 border-t border-slate-900/60"
        >
            <HowItWorksBehind client:load />
        </section>

        <!-- CÓMO FUNCIONA / SIMULADOR SECTION -->
        <section
            id="como-funciona"
            class="container mx-auto px-6 py-24 border-t border-slate-900/60"
        >
            <HowItWorks client:load />
        </section>

        <!-- GSAP & Lenis Animations -->
        <script>
            import { gsap } from "gsap";
            import { ScrollTrigger } from "gsap/ScrollTrigger";
            import Lenis from "lenis";

            // Initialize Lenis
            const lenis = new Lenis({
                duration: 1.2,
                easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                orientation: "vertical",
                gestureOrientation: "vertical",
                smoothWheel: true,
                wheelMultiplier: 1,
                smoothTouch: false,
                touchMultiplier: 2,
                infinite: false,
            });

            function raf(time) {
                lenis.raf(time);
                requestAnimationFrame(raf);
            }

            requestAnimationFrame(raf);

            gsap.registerPlugin(ScrollTrigger);

            // Sync ScrollTrigger with Lenis
            lenis.on("scroll", ScrollTrigger.update);

            gsap.ticker.add((time) => {
                lenis.raf(time * 1000);
            });

            gsap.ticker.lagSmoothing(0);

            // Entrance Timeline
            const tl = gsap.timeline({
                defaults: { ease: "power4.out", duration: 1.2 },
            });

            tl.to("#logo", { opacity: 1, y: 0, duration: 0.8 })
                .fromTo(
                    "#hero-badge",
                    { opacity: 0, y: -20 },
                    { opacity: 1, y: 0 },
                    "-=0.4",
                )
                .fromTo(
                    "#hero-title",
                    { opacity: 0, y: 30 },
                    { opacity: 1, y: 0 },
                    "-=0.6",
                )
                .fromTo(
                    "#hero-desc",
                    { opacity: 0, y: 20 },
                    { opacity: 1, y: 0 },
                    "-=0.8",
                )
                .fromTo(
                    "#hero-btn",
                    { opacity: 0, scale: 0.9 },
                    { opacity: 1, scale: 1 },
                    "-=0.8",
                )
                .fromTo(
                    ".metric-card",
                    { opacity: 0, y: 30 },
                    { opacity: 1, y: 0, stagger: 0.15, duration: 1 },
                    "-=0.8",
                );

            // Scroll Reveal for Predictor
            gsap.from("#agente", {
                scrollTrigger: {
                    trigger: "#agente",
                    start: "top 80%",
                },
                opacity: 0,
                y: 50,
                duration: 1.5,
                ease: "power3.out",
            });

            // Scroll Reveal for How It Works Behind
            gsap.from("#como-funciona-detras", {
                scrollTrigger: {
                    trigger: "#como-funciona-detras",
                    start: "top 80%",
                },
                opacity: 0,
                y: 50,
                duration: 1.5,
                ease: "power3.out",
            });

            // Scroll Reveal for How It Works
            gsap.from("#como-funciona", {
                scrollTrigger: {
                    trigger: "#como-funciona",
                    start: "top 80%",
                },
                opacity: 0,
                y: 50,
                duration: 1.5,
                ease: "power3.out",
            });
        </script>
    </body>
</html>
